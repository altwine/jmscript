func ge() -> number {
	player_send_message("test", "CONCATENATION")

	c := 1
	if c == 1 {
		return 1
	} else {
		return 3
	}
	return 4
}

event player_join() {
	a := 1
	_ :: a

	b := ge()
	_ :: b

	if b == 3 {
		player_send_message("UNRECHEIBL", "CONCATENATION")
	}
}
